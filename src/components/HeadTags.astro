<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new MutationObserver(() => {
      const wcLink = document.querySelector('a[href="https://webcontainers.io/"]');
      if (wcLink && !wcLink.dataset.replaced) {
        const cls = 'inline-block font-size-3.5 underline text-tk-elements-link-secondaryColor hover:text-tk-elements-link-secondaryColorHover';
        const attribution = document.createElement('p');
        attribution.style.cssText = 'margin-top:auto;font-size:0.875rem;';
        attribution.innerHTML =
          'Proudly built by <a href="https://chamoylabs.com" target="_blank" rel="noopener noreferrer" class="' + cls + '">Chamoy Labs</a>' +
          ' based on <a href="https://rubyllm.com/" target="_blank" rel="noopener noreferrer" class="' + cls + '">RubyLLM</a>' +
          ' by <a href="https://paolino.me/" target="_blank" rel="noopener noreferrer" class="' + cls + '">Carmine Paolino</a>.';
        wcLink.replaceWith(attribution);
        observer.disconnect();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });
  });
</script>

